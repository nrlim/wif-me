generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  JAMAAH
  MUTHAWIF
  PROVIDER
  ADMIN
}

enum VerificationStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ServiceType {
  MUTHAWIF_PERSONAL
  PROVIDER_MUTHAWIF
  TRANSPORTATION
  VISA_PROCESSING
  ADDITIONAL_SERVICE
}

enum CurrencyCode {
  IDR
  SAR
  USD
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  FAILED
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum WithdrawalStatus {
  REVIEW
  APPROVED
  PAID
  REJECTED
}

enum FinanceRuleKind {
  FEE
  CHARGE
}

enum FinanceRuleStatus {
  ACTIVE
  DRAFT
}

enum ServiceCategoryStatus {
  ACTIVE
  DRAFT
}

enum PriceModel {
  CURRENCY
  B2B
  ROUTE
  DOCUMENT
  CUSTOM
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique @db.VarChar(255)
  passwordHash  String         @db.VarChar(255)
  name          String         @db.VarChar(160)
  role          UserRole       @default(JAMAAH)
  phone         String?        @db.VarChar(32)
  emailVerified Boolean        @default(false)
  emailVerifiedAt DateTime?
  preferredCurrency CurrencyCode @default(IDR)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  providerProfile ProviderProfile?
  offeredServices ServiceOffering[] @relation("ServiceOwner")
  bookings      Booking[]      @relation("CustomerBookings")
  emailOtps     EmailOtp[]
  withdrawalRequests WithdrawalRequest[] @relation("ProviderWithdrawals")

  @@index([role])
  @@index([createdAt])
  @@map("wif_user")
}

model ProviderProfile {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String             @unique @db.Uuid
  displayName     String             @db.VarChar(180)
  bio             String?            @db.Text
  languages       String[]           @default([])
  baseCity        String?            @db.VarChar(120)
  verificationStatus VerificationStatus @default(DRAFT)
  verifiedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus])
  @@map("wif_provider_profile")
}

model ServiceCategory {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key             String                @unique @db.VarChar(80)
  slug            String                @unique @db.VarChar(100)
  serviceType     ServiceType           @unique
  title           String                @db.VarChar(160)
  description     String                @db.Text
  priceModel      PriceModel
  displayOrder    Int                   @default(1)
  status          ServiceCategoryStatus @default(DRAFT)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  offerings       ServiceOffering[]

  @@index([status, displayOrder])
  @@map("wif_service_category")
}

model ServiceOffering {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId         String        @db.Uuid
  categoryId      String?       @db.Uuid
  type            ServiceType
  title           String        @db.VarChar(180)
  description     String        @db.Text
  basePriceIdr    Decimal       @db.Decimal(14, 2)
  routeFrom       String?       @db.VarChar(120)
  routeTo         String?       @db.VarChar(120)
  isActive        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  owner           User          @relation("ServiceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  category        ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  bookings        Booking[]

  @@index([categoryId, isActive])
  @@index([type, isActive])
  @@index([ownerId])
  @@map("wif_service_offering")
}

model Booking {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId      String        @db.Uuid
  serviceOfferingId String      @db.Uuid
  status          BookingStatus @default(DRAFT)
  scheduledStart  DateTime
  scheduledEnd    DateTime?
  notes           String?       @db.Text
  totalPriceIdr   Decimal       @db.Decimal(14, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  customer        User          @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Restrict)
  serviceOffering ServiceOffering @relation(fields: [serviceOfferingId], references: [id], onDelete: Restrict)
  payment         Payment?

  @@index([status, createdAt])
  @@index([customerId, status])
  @@index([serviceOfferingId, scheduledStart])
  @@map("wif_booking")
}

model Payment {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId       String        @unique @db.Uuid
  status          PaymentStatus @default(PENDING)
  amountIdr       Decimal       @db.Decimal(14, 2)
  gatewayReference String?      @db.VarChar(180)
  escrowReleasedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([status])
  @@map("wif_payment")
}

model EmailOtp {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @db.Uuid
  purpose         OtpPurpose
  otpHash         String        @db.VarChar(128)
  expiresAt       DateTime
  consumedAt      DateTime?
  attempts        Int           @default(0)
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
  @@index([purpose, createdAt])
  @@map("wif_email_otp")
}

model WithdrawalRequest {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId      String           @db.Uuid
  status          WithdrawalStatus @default(REVIEW)
  amountIdr       Decimal          @db.Decimal(14, 2)
  bankName        String?          @db.VarChar(120)
  bankAccountLast4 String?         @db.VarChar(8)
  reviewedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  provider        User             @relation("ProviderWithdrawals", fields: [providerId], references: [id], onDelete: Restrict)

  @@index([providerId, status])
  @@index([status, createdAt])
  @@map("wif_withdrawal_request")
}

model FinanceRule {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key             String            @unique @db.VarChar(80)
  kind            FinanceRuleKind
  title           String            @db.VarChar(160)
  description     String            @db.Text
  value           String            @db.VarChar(80)
  status          FinanceRuleStatus @default(DRAFT)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([kind, status])
  @@map("wif_finance_rule")
}

model ExchangeRate {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  baseCurrency    CurrencyCode  @default(IDR)
  targetCurrency  CurrencyCode
  rate            Decimal       @db.Decimal(18, 8)
  fetchedAt       DateTime      @default(now())

  @@unique([baseCurrency, targetCurrency])
  @@index([fetchedAt])
  @@map("wif_exchange_rate")
}
